{
  "scheda_id": "SCHEDA_B_CRONICO",
  "nome": "Scheda B — Follow-up Patologia Cronica",
  "versione": "1.0",
  "anno": 2026,
  "pubblico_destinatario": "Assistito con ipertensione, diabete, BPCO/asma o anziano fragile",
  "linea_di_cura": "Cronicità / Anziano fragile",
  "frequenza_applicazione": "Mensile (scompensato: quindicinale). 12 colonne di visita = ~1 anno di follow-up.",
  "descrizione": "Follow-up periodico dell'assistito cronico al domicilio. Adattamento italiano della Ficha B Crônico SMS-Rio.",

  "sezioni": [
    { "id": "intestazione", "label": "Intestazione", "ordine": 1, "shared_ref": "_shared.intestazione_comune" },
    { "id": "identificazione", "label": "Identificazione dell'assistito", "ordine": 2, "shared_ref": "_shared.identificazione_assistito" },
    {
      "id": "quadro_clinico",
      "label": "Quadro clinico di base",
      "ordine": 3,
      "campi": [
        { "id": "patologie", "label": "Patologie", "tipo": "multi_enum", "valori": ["Ipertensione", "Diabete tipo 1", "Diabete tipo 2", "BPCO", "Asma", "Scompenso cardiaco", "Anziano fragile"] },
        { "id": "in_adi", "label": "In carico ADI?", "tipo": "boolean" },
        { "id": "piano_terapeutico", "label": "Piano terapeutico attivo?", "tipo": "boolean" }
      ]
    },
    {
      "id": "rilevazioni_per_visita",
      "label": "Rilevazioni per visita (12 colonne)",
      "ordine": 4,
      "ripetibile_per_visita": true,
      "campi": [
        { "id": "pressione_arteriosa", "label": "Pressione arteriosa (mmHg)", "tipo": "string", "esempio": "140/90" },
        { "id": "glicemia_capillare", "label": "Glicemia capillare (mg/dl)", "tipo": "integer", "solo_per": ["Diabete tipo 1", "Diabete tipo 2"] },
        { "id": "peso", "label": "Peso (kg)", "tipo": "decimal" },
        { "id": "aderenza_terapia", "label": "Aderenza alla terapia", "tipo": "enum", "enum_ref": "_shared.enums.aderenza_terapia" },
        { "id": "farmaci_disponibili", "label": "Farmaci disponibili a casa?", "tipo": "boolean" },
        { "id": "dieta_seguita", "label": "Segue le indicazioni alimentari?", "tipo": "boolean" },
        { "id": "attivita_fisica", "label": "Attività fisica?", "tipo": "boolean" },
        { "id": "fumo", "label": "Fumatore?", "tipo": "boolean" },
        { "id": "sintomi_allarme", "label": "Sintomi d'allarme (dispnea, edemi, dolore toracico)?", "tipo": "boolean" },
        { "id": "cadute_recenti", "label": "Cadute negli ultimi 30 giorni?", "tipo": "boolean", "solo_per": ["Anziano fragile"] },
        { "id": "visita_specialistica_programmata", "label": "Visita specialistica programmata comunicata?", "tipo": "boolean" }
      ]
    },
    { "id": "esito", "label": "Esito della visita", "ordine": 5, "shared_ref": "_shared.esito_visita" }
  ]
}
